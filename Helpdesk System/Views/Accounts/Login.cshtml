@model Helpdesk_System.ViewModels.Accounts.LoginViewModel

@{
    ViewData["Title"] = "Logowanie";
}

<section class="auth-page">
    <div class="auth-card">
        <h1>Helpdesk System</h1>
        <h2>Logowanie</h2>

        <form asp-controller="Accounts" asp-action="Login" method="post" class="auth-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" autocomplete="username" />
                <span asp-validation-for="Email" class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-validation"></span>
            </div>

            <div class="form-check">
                <input asp-for="RememberMe" />
                <label asp-for="RememberMe"></label>
            </div>

            <button type="submit" class="primary-button">Zaloguj</button>
        </form>
    </div>
</section>
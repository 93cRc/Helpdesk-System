@model IEnumerable<Helpdesk_System.Models.Entities.Ticket>

@{
    ViewData["Title"] = "Zgłoszenia";
}

<h1>Zgłoszenia</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">
        Nowe zgłoszenie
    </a>
</div>
<form method="get" class="row g-3 mb-3">

    <div class="col-md-4">
        <label class="form-label">Status</label>

        <select name="statusId" class="form-select">
            <option value="">Wszystkie</option>

            @foreach (var status in ViewBag.Statuses)
            {
                if (ViewBag.SelectedStatusId == status.Id)
                {
                    <option value="@status.Id" selected>
                        @status.Name
                    </option>
                }
                else
                {
                    <option value="@status.Id">
                        @status.Name
                    </option>
                }
            }
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label">Priorytet</label>

        <select name="priorityId" class="form-select">
            <option value="">Wszystkie</option>

            @foreach (var priority in ViewBag.Priorities)
            {
                if (ViewBag.SelectedPriorityId == priority.Id)
                {
                    <option value="@priority.Id" selected>
                        @priority.Name
                    </option>
                }
                else
                {
                    <option value="@priority.Id">
                        @priority.Name
                    </option>
                }
            }
        </select>
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">
            Filtruj
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Wyczyść
        </a>
    </div>

</form>

@if (!Model.Any())
{
    <p>Brak zgłoszeń.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tytuł</th>
                <th>Status</th>
                <th>Priorytet</th>
                <th>Data utworzenia</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in Model)
            {
                <tr>
                    <td>@ticket.Id</td>

                    <td>
                        <a asp-action="Details"
                               asp-route-id="@ticket.Id">
                            @ticket.Title
                        </a>
                    </td>

                    <td>@ticket.Status?.Name</td>

                    <td>@ticket.Priority?.Name</td>

                    <td>@ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                    <td>
                        <a asp-action="Details"
                               asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-primary">
                            Szczegóły
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
@model IEnumerable<Helpdesk_System.Models.Entities.Ticket>

@{
    ViewData["Title"] = "Zgłoszenia";
}

<h1>Zgłoszenia</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">
        Nowe zgłoszenie
    </a>
</div>

@if (!Model.Any())
{
    <p>Brak zgłoszeń.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tytuł</th>
                <th>Status</th>
                <th>Priorytet</th>
                <th>Data utworzenia</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in Model)
            {
                <tr>
                    <td>@ticket.Id</td>

                    <td>
                        <a asp-action="Details"
                               asp-route-id="@ticket.Id">
                            @ticket.Title
                        </a>
                    </td>

                    <td>@ticket.Status?.Name</td>

                    <td>@ticket.Priority?.Name</td>

                    <td>@ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                    <td>
                        <a asp-action="Details"
                               asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-primary">
                            Szczegóły
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
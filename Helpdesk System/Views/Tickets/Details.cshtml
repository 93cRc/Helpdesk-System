@model Helpdesk_System.Models.Entities.Ticket

@{
    ViewData["Title"] = "Szczegóły zgłoszenia";
    var isClosed = Model.StatusId == 7;
}
@{
    var canManageTickets =
        User.IsInRole("Admin") ||
        User.IsInRole("Agent");
}

<h1>Szczegóły zgłoszenia</h1>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">Powrót</a>
</div>

@if (isClosed)
{
    <div class="alert alert-secondary">
        To zgłoszenie jest zamknięte.
    </div>
}

<div class="card">
    <div class="card-body">
        <h3>@Model.Title</h3>

        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Status:</strong> @Model.Status?.Name</p>

        @if (!isClosed && canManageTickets)
        {
            <form asp-action="ChangeStatus" method="post">
                <input type="hidden" name="ticketId" value="@Model.Id" />

                <select name="statusId" class="form-control" required>
                    <option value="">-- wybierz nowy status --</option>

                    @foreach (var status in ViewBag.Statuses)
                    {
                        if (status.Id != Model.StatusId && status.Id != 7)
                        {
                            <option value="@status.Id">
                                @status.Name
                            </option>
                        }
                    }
                </select>

                <br />

                <button type="submit" class="btn btn-primary">
                    Zmień status
                </button>
            </form>

            <form asp-action="CloseTicket" method="post" class="mt-2">
                <input type="hidden" name="ticketId" value="@Model.Id" />

                <div class="mb-2">
                    <label class="form-label">Komentarz zamknięcia</label>
                    <textarea name="closeComment"
                              class="form-control"
                              rows="3"
                              placeholder="Opisz, w jaki sposób zgłoszenie zostało zakończone..."
                              required></textarea>
                </div>

                <button type="submit" class="btn btn-danger">
                    Zamknij zgłoszenie
                </button>
            </form>
        }

        <p class="mt-3"><strong>Priorytet:</strong> @Model.Priority?.Name</p>
        <p><strong>Kategoria:</strong> @(Model.Category?.Name ?? "Brak")</p>
        <p><strong>Dział:</strong> @(Model.Department?.Name ?? "Brak")</p>
        <p><strong>Opis:</strong> @(Model.Description ?? "Brak opisu")</p>
        <p><strong>Data utworzenia:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
        <p><strong>Zgłaszający:</strong> @Model.Requestor?.FirstName @Model.Requestor?.LastName</p>

        <p>
            <strong>Agent:</strong>
            @(Model.Agent == null
                ? "Nieprzypisany"
                : $"{Model.Agent.FirstName} {Model.Agent.LastName}")
        </p>

        @if (!isClosed && canManageTickets)
        {
            <form asp-action="AssignAgent" method="post">
                <input type="hidden" name="ticketId" value="@Model.Id" />

                <select name="agentId" class="form-control">
                    <option value="">-- wybierz agenta --</option>

                    @foreach (var agent in ViewBag.Agents)
                    {
                        if (Model.AgentId == agent.Id)
                        {
                            <option value="@agent.Id" selected>
                                @agent.FirstName @agent.LastName
                            </option>
                        }
                        else
                        {
                            <option value="@agent.Id">
                                @agent.FirstName @agent.LastName
                            </option>
                        }
                    }
                </select>

                <br />

                <button type="submit" class="btn btn-primary">
                    Przypisz agenta
                </button>
            </form>
        }
    </div>

    <hr />

    <div class="card-body">
        <h3>Komentarze</h3>

        @if (Model.Comments.Any())
        {
            @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
            {
                <div class="card mb-2">
                    <div class="card-body">
                        <strong>
                            @comment.User?.FirstName @comment.User?.LastName
                        </strong>

                        <small class="text-muted">
                            (@comment.CreatedAt.ToString("yyyy-MM-dd HH:mm"))
                        </small>

                        <p class="mt-2 mb-0">
                            @comment.Content
                        </p>
                    </div>
                </div>
            }
        }
        else
        {
            <p>Brak komentarzy.</p>
        }

        <hr />

        @if (!isClosed)
        {
            <h4>Dodaj komentarz</h4>

            <form asp-action="AddComment" method="post">
                <input type="hidden" name="ticketId" value="@Model.Id" />

                <div class="mb-3">
                    <textarea name="content"
                              class="form-control"
                              rows="4"
                              placeholder="Wpisz komentarz..."></textarea>
                </div>

                <button type="submit" class="btn btn-success">
                    Dodaj komentarz
                </button>
            </form>
        }
        else
        {
            <p class="text-muted">
                Dodawanie komentarzy jest zablokowane, ponieważ zgłoszenie jest zamknięte.
            </p>
        }

        <hr />

        <h3>Historia zmian</h3>

        @if (Model.History != null && Model.History.Any())
        {
            @foreach (var history in Model.History.OrderByDescending(h => h.HistoryCreatedAt))
            {
                <div class="card mb-2">
                    <div class="card-body">
                        <strong>
                            @history.HistoryCreatedAt.ToString("yyyy-MM-dd HH:mm")
                        </strong>

                        <p class="mb-1">
                            Status:
                            @(history.Status?.Name ?? "Brak")
                        </p>

                        <p class="mb-1">
                            Agent:
                            @(history.Agent == null
                                ? "Nieprzypisany"
                                : $"{history.Agent.FirstName} {history.Agent.LastName}")
                        </p>

                        <small class="text-muted">
                            Zmienione przez:
                            @(history.ChangedByUser == null
                                ? "Brak danych"
                                : $"{history.ChangedByUser.FirstName} {history.ChangedByUser.LastName}")
                        </small>
                    </div>
                </div>
            }
        }
        else
        {
            <p>Brak historii zmian.</p>
        }
    </div>
</div>
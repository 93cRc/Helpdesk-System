@model Helpdesk_System.ViewModels.Departments.DepartmentDeleteViewModel

<div class="mb-4">
    <h1 class="mb-1">Usuń dział</h1>
    <p class="text-muted mb-0">Potwierdź usunięcie działu z systemu helpdesk</p>
</div>

<div class="card">
    <div class="card-header fw-bold">
        Usuwanie działu
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            Czy na pewno chcesz usunąć ten dział?
        </div>

        <dl class="row mb-4">
            <dt class="col-sm-3">Nazwa działu</dt>
            <dd class="col-sm-9">@Model.Name</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-outline-danger">Usuń</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>
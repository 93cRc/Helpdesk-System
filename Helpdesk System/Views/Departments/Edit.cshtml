@model Helpdesk_System.ViewModels.Departments.DepartmentEditViewModel

<div class="mb-4">
    <h1 class="mb-1">Edytuj dział</h1>
    <p class="text-muted mb-0">Zmień dane działu w systemie helpdesk</p>
</div>

<div class="card">
    <div class="card-header fw-bold">
        Edycja działu
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Nazwa działu</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary">Zapisz zmiany</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Powrót</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
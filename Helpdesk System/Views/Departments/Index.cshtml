@model IEnumerable<Helpdesk_System.ViewModels.Departments.DepartmentIndexViewModel>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Działy</h1>
        <p class="text-muted mb-0">Lista działów w systemie helpdesk</p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary btn-lg">+ Dodaj dział</a>
    }
</div>

<div class="card">
    <div class="card-header fw-bold">
        Lista działów
    </div>
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-3">
                <div class="alert alert-light border mb-0">
                    Brak działów w bazie.
                </div>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nazwa działu</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="color: #3d5a80; font-weight: 700;">@item.Name</td>
                            <td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm me-2">
                                        Edytuj
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                                        Usuń
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
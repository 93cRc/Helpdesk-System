@model Helpdesk_System.ViewModels.Users.CreateUserResultViewModel

<div class="mb-4">
    <h1 class="mb-1">Utworzono użytkownika</h1>
    <p class="text-muted mb-0">Konto zostało utworzone, a hasło wygenerowane automatycznie</p>
</div>

<div class="card">
    <div class="card-header fw-bold">
        Wygenerowane hasło
    </div>

    <div class="card-body">
        <div class="alert alert-warning border">
            Zapisz lub przekaż to hasło użytkownikowi. Po opuszczeniu tej strony hasło nie będzie ponownie widoczne.
        </div>

        <dl class="row">
            <dt class="col-sm-3">Użytkownik</dt>
            <dd class="col-sm-9" style="color: #3d5a80; font-weight: 700;">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Hasło</dt>
            <dd class="col-sm-9">
                <code class="fs-5">@Model.GeneratedPassword</code>
            </dd>
        </dl>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Details" asp-route-id="@Model.UserId" class="btn btn-outline-primary">Szczegóły użytkownika</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Lista użytkowników</a>
        </div>
    </div>
</div>

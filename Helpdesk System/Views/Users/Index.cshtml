@model Helpdesk_System.ViewModels.Users.UserIndexViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Użytkownicy</h1>
        <p class="text-muted mb-0">Lista użytkowników w systemie helpdesk</p>
    </div>

    @if (User.IsInRole("Admin")) {
        <a asp-action="Create" class="btn btn-primary btn-lg">
            + Dodaj użytkownika
        </a>
    }
</div>

<div class="card">
    <div class="card-header fw-bold">
        Lista użytkowników
    </div>

    <div class="card-body p-0">
        @if (Model == null || Model.Users == null || !Model.Users.Any()) {
            <div class="p-3">
                <div class="alert alert-light border mb-0">
                    Brak użytkowników w bazie.
                </div>
            </div>
        }
        else {
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Użytkownik</th>
                        <th>Email</th>
                        <th>Rola</th>
                        <th>Dział</th>
                        <th>Status</th>
                        <th>Akcje</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Users) {
                        <tr>
                            <td style="color: #3d5a80; font-weight: 700;">
                                @item.FirstName @item.LastName
                            </td>

                            <td>@item.Email</td>

                            <td>
                                <span class="badge bg-primary">
                                    @item.RoleName
                                </span>
                            </td>

                            <td>
                                @if (string.IsNullOrWhiteSpace(item.DepartmentName)) {
                                    <span class="text-muted">Brak</span>
                                }
                                else {
                                    <span class="badge bg-info text-dark">
                                        @item.DepartmentName
                                    </span>
                                }
                            </td>

                            <td>
                                @if (item.IsActive) {
                                    <span class="badge bg-success">
                                        Aktywny
                                    </span>
                                }
                                else {
                                    <span class="badge bg-secondary">
                                        Nieaktywny
                                    </span>
                                }
                            </td>

                            <td>
                                @if (User.IsInRole("Admin")) {
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-primary btn-sm me-2">
                                        Edytuj
                                    </a>

                                    <form asp-action="ResetPassword"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          class="d-inline">
                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-outline-warning btn-sm me-2"
                                                onclick="return confirm('Czy na pewno zresetować hasło użytkownika?');">
                                            Reset hasła
                                        </button>
                                    </form>

                                    @if (item.IsActive) {
                                        <a asp-action="Deactivate"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-danger btn-sm">
                                            Dezaktywuj
                                        </a>
                                    }
                                    else {
                                        <form asp-action="Activate"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-outline-success btn-sm">
                                                Aktywuj
                                            </button>
                                        </form>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
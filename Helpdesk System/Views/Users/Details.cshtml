@model Helpdesk_System.ViewModels.Users.UserDetailsViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Szczegóły użytkownika</h1>
        <p class="text-muted mb-0">Podgląd danych konta użytkownika</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Powrót</a>
</div>

<div class="card">
    <div class="card-header fw-bold">
        Dane użytkownika
    </div>

    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Imię i nazwisko</dt>
            <dd class="col-sm-9" style="color: #3d5a80; font-weight: 700;">@Model.FirstName @Model.LastName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Telefon</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</dd>

            <dt class="col-sm-3">Rola</dt>
            <dd class="col-sm-9">@Model.RoleName</dd>

            <dt class="col-sm-3">Dział</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.DepartmentName) ? "-" : Model.DepartmentName)</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive) {
                    <span class="badge bg-success">Aktywny</span>
                }
                else {
                    <span class="badge bg-secondary">Nieaktywny</span>
                }
            </dd>

            <dt class="col-sm-3">Utworzono</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Ostatnia aktualizacja</dt>
            <dd class="col-sm-9">@(Model.UpdatedAt.HasValue? Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "-")</dd>

            <dt class="col-sm-3">Ostatnie logowanie</dt>
            <dd class="col-sm-9">@(Model.LastLoginAt.HasValue? Model.LastLoginAt.Value.ToString("yyyy-MM-dd HH:mm") : "Nigdy")</dd>
        </dl>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edytuj</a>

            <form asp-action="ResetPassword" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-warning">Reset hasła</button>
            </form>

            @if (Model.IsActive) {
                <a asp-action="Deactivate" asp-route-id="@Model.Id" class="btn btn-outline-danger">Dezaktywuj</a>
            }
            else {
                <form asp-action="Activate" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-success">Aktywuj</button>
                </form>
            }
        </div>
    </div>
</div>

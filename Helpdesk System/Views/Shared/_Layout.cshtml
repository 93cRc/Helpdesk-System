<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Helpdesk System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Helpdesk_System.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<body>
    <header class="app-header">
        <nav class="app-nav">
            <div class="app-nav__brand">
                <a asp-controller="Home" asp-action="Index">Helpdesk System</a>
            </div>

            <div class="app-nav__links">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Home" asp-action="Index">Start</a>
                    <a asp-controller="Tickets" asp-action="Index">Zgłoszenia</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Users" asp-action="Index">Użytkownicy</a>
                        <a asp-controller="Departments" asp-action="Index">Działy</a>
                        <a asp-controller="Categories" asp-action="Index">Kategorie</a>
                        <a asp-controller="Departments" asp-action="Index">Działy</a>
                    }

                    <span class="app-nav__user">
                        @User.Identity.Name
                    </span>

                    <form asp-controller="Accounts" asp-action="Logout" method="post" class="app-nav__logout-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="link-button">Wyloguj</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Accounts" asp-action="Login">Logowanie</a>
                }
            </div>
        </nav>
    </header>

    <main class="app-main">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <span>&copy; 2026 - Helpdesk System</span>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>